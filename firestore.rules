rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para a coleção de atletas
    match /atletas/{document=**} {
      // 1. Inscrição Pública (Sem Login):
      // Permite criar ficha APENAS se o status for 'Pendente'.
      allow create: if request.resource.data.status == 'Pendente';
      
      // 2. Área Administrativa (Com Login):
      // Permite Ler, Criar, Editar (Update) e Excluir (Delete) qualquer documento
      // desde que o usuário esteja autenticado no Firebase Auth.
      allow read, write: if request.auth != null;
    }
  }
}